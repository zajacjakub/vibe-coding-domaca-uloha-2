{
  "shop": {
    "url": "https://your-shop.example.com",
    "name": "Your Brand"
  },
  "report": {
    "language": "en"
  },
  "links": {
    "cache_max_age_days": 7,
    "whitelist_domains": [
      "instagram.com",
      "facebook.com",
      "linkedin.com",
      "twitter.com",
      "x.com",
      "tiktok.com",
      "medium.com",
      "t.co",
      "bit.ly",
      "goo.gl"
    ]
  },
  "ux": {
    "viewports": [375, 768, 1280],
    "sample_size": { "products": 10, "articles": 10 },
    "skip_flows": ["checkout-submit"],
    "performance_budget_lcp_ms": 2500
  }
}

